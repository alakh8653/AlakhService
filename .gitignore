*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
lib/
lib64/
MANIFEST

# Virtual environments
.env
.venv
venv/
env/
ENV/
env.bak/
venv.bak/

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
coverage/
htmlcov/
nosetests.xml
coverage.xml
*.cover
*.py,cover
