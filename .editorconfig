# =============================================================================
# AlakhService – EditorConfig
# https://editorconfig.org
# =============================================================================

root = true

# ---------------------------------------------------------------------------
# Global defaults
# ---------------------------------------------------------------------------
[*]
charset                  = utf-8
end_of_line              = lf
indent_size              = 2
indent_style             = space
insert_final_newline     = true
max_line_length          = 120
trim_trailing_whitespace = true

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
[*.{py,pyi}]
indent_size    = 4
max_line_length = 88     # matches Black formatter default

# ---------------------------------------------------------------------------
# Dart / Flutter
# ---------------------------------------------------------------------------
[*.dart]
indent_size    = 2
max_line_length = 80

# ---------------------------------------------------------------------------
# TypeScript / JavaScript / JSX / TSX
# ---------------------------------------------------------------------------
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size    = 2
max_line_length = 120

# ---------------------------------------------------------------------------
# JSON / JSON5
# ---------------------------------------------------------------------------
[*.{json,json5,jsonc}]
indent_size = 2

# ---------------------------------------------------------------------------
# YAML
# ---------------------------------------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# ---------------------------------------------------------------------------
# TOML
# ---------------------------------------------------------------------------
[*.toml]
indent_size = 2

# ---------------------------------------------------------------------------
# HTML / Templates
# ---------------------------------------------------------------------------
[*.{html,htm,jinja,jinja2,j2}]
indent_size = 2

# ---------------------------------------------------------------------------
# CSS / SCSS / Less
# ---------------------------------------------------------------------------
[*.{css,scss,sass,less}]
indent_size = 2

# ---------------------------------------------------------------------------
# Markdown
# ---------------------------------------------------------------------------
[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length          = off

# ---------------------------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------------------------
[*.{sh,bash,zsh,fish}]
indent_size = 2

# ---------------------------------------------------------------------------
# Makefile (MUST use hard tabs)
# ---------------------------------------------------------------------------
[Makefile]
indent_style = tab
indent_size  = 4

[*.mk]
indent_style = tab
indent_size  = 4

# ---------------------------------------------------------------------------
# Go
# ---------------------------------------------------------------------------
[*.go]
indent_style = tab
indent_size  = 4

# ---------------------------------------------------------------------------
# Rust
# ---------------------------------------------------------------------------
[*.rs]
indent_size    = 4
max_line_length = 100

# ---------------------------------------------------------------------------
# Terraform / HCL
# ---------------------------------------------------------------------------
[*.{tf,tfvars,hcl}]
indent_size = 2

# ---------------------------------------------------------------------------
# Dockerfile
# ---------------------------------------------------------------------------
[Dockerfile*]
indent_size = 2

# ---------------------------------------------------------------------------
# Docker Compose
# ---------------------------------------------------------------------------
[docker-compose*.yml]
indent_size = 2

# ---------------------------------------------------------------------------
# Proto / gRPC
# ---------------------------------------------------------------------------
[*.proto]
indent_size = 2

# ---------------------------------------------------------------------------
# SQL
# ---------------------------------------------------------------------------
[*.sql]
indent_size = 4

# ---------------------------------------------------------------------------
# Gradle
# ---------------------------------------------------------------------------
[*.gradle]
indent_size = 4

# ---------------------------------------------------------------------------
# XML / SVG
# ---------------------------------------------------------------------------
[*.{xml,svg}]
indent_size = 2

# ---------------------------------------------------------------------------
# Config files
# ---------------------------------------------------------------------------
[*.{conf,cfg,ini}]
indent_size = 2

# ---------------------------------------------------------------------------
# Lock files – leave as-is
# ---------------------------------------------------------------------------
[{package-lock.json,yarn.lock,pnpm-lock.yaml,Cargo.lock,poetry.lock}]
insert_final_newline     = false
trim_trailing_whitespace = false
