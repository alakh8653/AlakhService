# =============================================================================
# AlakhService — Root Environment Configuration
# Copy to .env and fill in real values
# WARNING: Never commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/alakhservice_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-super-secret-jwt-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# Service URLs
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:8001
USER_SERVICE_URL=http://localhost:8002
SHOP_SERVICE_URL=http://localhost:8003
BOOKING_SERVICE_URL=http://localhost:8004
PAYMENT_SERVICE_URL=http://localhost:8005
NOTIFICATION_SERVICE_URL=http://localhost:8006
TRACKING_SERVICE_URL=http://localhost:8007
QUEUE_SERVICE_URL=http://localhost:8008
DISPATCH_SERVICE_URL=http://localhost:8009
ANALYTICS_SERVICE_URL=http://localhost:8010
DISPUTE_SERVICE_URL=http://localhost:8011
TRUST_RISK_SERVICE_URL=http://localhost:8012
ADMIN_SERVICE_URL=http://localhost:8013
COMPLIANCE_SERVICE_URL=http://localhost:8014
PRICING_ENGINE_URL=http://localhost:8015
SERVICE_CATALOG_URL=http://localhost:8016

# -----------------------------------------------------------------------------
# Payment Gateway
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# -----------------------------------------------------------------------------
# SMS Provider
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@alakhservice.com

# -----------------------------------------------------------------------------
# Firebase (Push notifications)
# -----------------------------------------------------------------------------
FIREBASE_SERVER_KEY=your-firebase-server-key

# -----------------------------------------------------------------------------
# AWS S3
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=ap-south-1
S3_BUCKET_NAME=alakhservice-media

# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
