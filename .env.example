# =============================================================================

# AlakhService – Environment Variables Reference
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual secrets
#
# Sections:
#   - Application
#   - Database (PostgreSQL)
#   - Cache (Redis)
#   - Message Broker (Kafka)
#   - Search (Elasticsearch)
#   - Authentication / JWT
#   - OAuth2 Providers
#   - Object Storage (S3 / GCS / MinIO)
#   - Email (SMTP)
#   - SMS / Push Notifications
#   - Payment Gateways
#   - Maps / Geolocation
#   - Observability (Prometheus, Jaeger, Sentry)
#   - Rate Limiting
#   - Feature Flags
#   - Service Endpoints (inter-service communication)
#   - Docker / Kubernetes
#   - Terraform / Cloud
# =============================================================================


# =============================================================================
# APPLICATION
# =============================================================================

# Runtime environment: development | staging | production | test
NODE_ENV=development
PYTHON_ENV=development
APP_ENV=development

# Application metadata
APP_NAME=AlakhService
APP_VERSION=1.0.0
APP_DOMAIN=localhost
APP_URL=http://localhost:3000

# Debug mode (true in dev, false in prod)
DEBUG=true

# Log level: debug | info | warn | error | critical
LOG_LEVEL=debug

# Log format: json | pretty
LOG_FORMAT=pretty

# Timezone (IANA format)
TZ=UTC

# Master encryption key (AES-256, 32-byte hex string)
# Generate: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_hex_32


# =============================================================================
# API GATEWAY
# =============================================================================

API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_WORKERS=4
API_GATEWAY_TIMEOUT=30

# Allowed CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# Request body size limit
MAX_REQUEST_SIZE_MB=10

# API versioning prefix
API_VERSION_PREFIX=/api/v1


# =============================================================================
# DATABASE – PostgreSQL (Primary)
# =============================================================================

# Main service database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=alakhservice
POSTGRES_USER=alakh
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_SSL_MODE=prefer

# Connection pool settings
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=3600

# Full connection URL (auto-assembled if individual vars provided)
DATABASE_URL=postgresql+asyncpg://alakh:changeme_strong_password@localhost:5432/alakhservice

# Read replica (optional, for read-heavy workloads)
DATABASE_REPLICA_URL=postgresql+asyncpg://alakh:changeme_strong_password@localhost:5432/alakhservice

# Auth service DB
AUTH_DATABASE_URL=postgresql+asyncpg://alakh:changeme_strong_password@localhost:5432/alakh_auth

# User service DB
USER_DATABASE_URL=postgresql+asyncpg://alakh:changeme_strong_password@localhost:5432/alakh_users

# Shop service DB
SHOP_DATABASE_URL=postgresql+asyncpg://alakh:changeme_strong_password@localhost:5432/alakh_shop

# Booking service DB
BOOKING_DATABASE_URL=postgresql+asyncpg://alakh:changeme_strong_password@localhost:5432/alakh_booking

# Payment service DB
PAYMENT_DATABASE_URL=postgresql+asyncpg://alakh:changeme_strong_password@localhost:5432/alakh_payment

# Notification service DB
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://alakh:changeme_strong_password@localhost:5432/alakh_notification

# Tracking service DB
TRACKING_DATABASE_URL=postgresql+asyncpg://alakh:changeme_strong_password@localhost:5432/alakh_tracking

# Migration tool
ALEMBIC_CONFIG=alembic.ini


# =============================================================================
# CACHE – Redis
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_DB=0
REDIS_URL=redis://:changeme_redis_password@localhost:6379/0

# TLS (enable in production)
REDIS_SSL=false

# Sentinel (for HA)
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_MASTER=mymaster
# REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379,sentinel3:26379

# Session cache DB
REDIS_SESSION_DB=1
REDIS_SESSION_TTL_SECONDS=86400

# Rate-limit cache DB
REDIS_RATE_LIMIT_DB=2

# Job queue DB
REDIS_QUEUE_DB=3


# =============================================================================
# MESSAGE BROKER – Apache Kafka
# =============================================================================

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# For multi-broker: KAFKA_BOOTSTRAP_SERVERS=broker1:9092,broker2:9092,broker3:9092

KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# Production (SASL_SSL):
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=alakh-kafka-user
# KAFKA_SASL_PASSWORD=changeme_kafka_password
# KAFKA_SSL_CA_LOCATION=/certs/ca.pem

KAFKA_CLIENT_ID=alakhservice
KAFKA_GROUP_ID=alakhservice-consumers
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_MAX_POLL_RECORDS=500

# Topics
KAFKA_TOPIC_USER_EVENTS=user.events
KAFKA_TOPIC_ORDER_EVENTS=order.events
KAFKA_TOPIC_PAYMENT_EVENTS=payment.events
KAFKA_TOPIC_NOTIFICATION_EVENTS=notification.events
KAFKA_TOPIC_BOOKING_EVENTS=booking.events
KAFKA_TOPIC_TRACKING_EVENTS=tracking.events
KAFKA_TOPIC_AUDIT_EVENTS=audit.events
KAFKA_TOPIC_DLQ=alakhservice.dlq

# Schema Registry (Confluent)
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081


# =============================================================================
# SEARCH – Elasticsearch
# =============================================================================

ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme_elastic_password
ELASTICSEARCH_INDEX_PREFIX=alakh

# TLS
ELASTICSEARCH_VERIFY_CERTS=false
# ELASTICSEARCH_CA_CERTS=/certs/ca.crt

# Index settings
ELASTICSEARCH_NUMBER_OF_SHARDS=1
ELASTICSEARCH_NUMBER_OF_REPLICAS=0


# =============================================================================
# AUTHENTICATION – JWT
# =============================================================================

# RS256 keys (generate: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem

# Or use symmetric secret (HS256) for simpler setups:
JWT_SECRET_KEY=changeme_jwt_secret_min_32_chars_long_very_secret
JWT_ALGORITHM=HS256

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=alakhservice
JWT_AUDIENCE=alakhservice-api

# Cookie settings
JWT_COOKIE_SECURE=false
JWT_COOKIE_HTTPONLY=true
JWT_COOKIE_SAMESITE=lax


# =============================================================================
# OAUTH2 PROVIDERS
# =============================================================================

# Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# Facebook
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/facebook/callback

# Apple
APPLE_CLIENT_ID=com.alakhservice.app
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID
APPLE_KEY_ID=YOUR_APPLE_KEY_ID
APPLE_PRIVATE_KEY_PATH=./secrets/apple_auth_key.p8


# =============================================================================
# OBJECT STORAGE
# =============================================================================

# Provider: s3 | gcs | minio | azure-blob
STORAGE_PROVIDER=minio

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=alakhservice-assets
AWS_S3_ENDPOINT_URL=           # Leave empty for real S3, set for MinIO/LocalStack
AWS_S3_USE_SSL=true
AWS_S3_PRESIGNED_URL_EXPIRY=3600

# MinIO (dev)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=alakhservice
MINIO_USE_SSL=false

# GCS
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-service-account.json
GCS_BUCKET=alakhservice-assets
GCS_PROJECT_ID=your-gcp-project-id

# CDN
CDN_BASE_URL=https://cdn.alakhservice.com


# =============================================================================
# EMAIL – SMTP
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=noreply@alakhservice.com
SMTP_PASSWORD=changeme_smtp_password
EMAIL_FROM_ADDRESS=noreply@alakhservice.com
EMAIL_FROM_NAME=AlakhService

# Optional: SendGrid / Mailgun / AWS SES
SENDGRID_API_KEY=SG.changeme_sendgrid_api_key
MAILGUN_API_KEY=key-changeme_mailgun_api_key
MAILGUN_DOMAIN=mg.alakhservice.com
AWS_SES_REGION=us-east-1


# =============================================================================
# SMS NOTIFICATIONS – Twilio / Firebase
# =============================================================================

TWILIO_ACCOUNT_SID=ACchangeme_twilio_account_sid
TWILIO_AUTH_TOKEN=changeme_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555555555

# Firebase Cloud Messaging (push notifications)
FIREBASE_PROJECT_ID=alakhservice-firebase
FIREBASE_CREDENTIALS_PATH=./secrets/firebase-adminsdk.json
FCM_SERVER_KEY=changeme_fcm_server_key

# APNs (Apple Push Notification service)
APNS_KEY_ID=YOUR_APNS_KEY_ID
APNS_TEAM_ID=YOUR_APNS_TEAM_ID
APNS_PRIVATE_KEY_PATH=./secrets/apns_key.p8
APNS_BUNDLE_ID=com.alakhservice.app
APNS_SANDBOX=true


# =============================================================================
# PAYMENT GATEWAYS
# =============================================================================

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_changeme
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme
STRIPE_API_VERSION=2024-04-10

# PayPal
PAYPAL_CLIENT_ID=changeme_paypal_client_id
PAYPAL_CLIENT_SECRET=changeme_paypal_client_secret
PAYPAL_MODE=sandbox

# Razorpay (India)
RAZORPAY_KEY_ID=rzp_test_changeme
RAZORPAY_KEY_SECRET=changeme_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=changeme_razorpay_webhook_secret


# =============================================================================
# MAPS / GEOLOCATION
# =============================================================================

GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_ACCESS_TOKEN=pk.eyJ1changeme
HERE_API_KEY=your-here-api-key


# =============================================================================
# OBSERVABILITY
# =============================================================================

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Jaeger distributed tracing
JAEGER_ENABLED=true
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=probabilistic
JAEGER_SAMPLER_PARAM=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=alakhservice

# Sentry error tracking
SENTRY_DSN=https://changeme@o000000.ingest.sentry.io/0000000
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
GRAFANA_URL=http://localhost:3003


# =============================================================================
# RATE LIMITING
# =============================================================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_REQUESTS=100
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60

RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60

RATE_LIMIT_API_REQUESTS=1000
RATE_LIMIT_API_WINDOW_SECONDS=3600


# =============================================================================
# FEATURE FLAGS (LaunchDarkly / Unleash / Custom)
# =============================================================================

FEATURE_FLAGS_ENABLED=true
UNLEASH_URL=http://localhost:4242
UNLEASH_API_KEY=default:development.changeme_unleash_api_key
LAUNCHDARKLY_SDK_KEY=sdk-changeme


# =============================================================================
# SERVICE ENDPOINTS (inter-service communication)
# =============================================================================

# Internal base URLs (used when services call each other)
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
SHOP_SERVICE_URL=http://shop-service:8003
BOOKING_SERVICE_URL=http://booking-service:8004
PAYMENT_SERVICE_URL=http://payment-service:8005
NOTIFICATION_SERVICE_URL=http://notification-service:8006
TRACKING_SERVICE_URL=http://tracking-service:8007

# gRPC ports
AUTH_GRPC_PORT=50051
USER_GRPC_PORT=50052
SHOP_GRPC_PORT=50053
BOOKING_GRPC_PORT=50054
PAYMENT_GRPC_PORT=50055
NOTIFICATION_GRPC_PORT=50056
TRACKING_GRPC_PORT=50057

# Service-to-service auth token
SERVICE_AUTH_TOKEN=changeme_internal_service_token


# =============================================================================
# WEBSOCKET / REAL-TIME
# =============================================================================

WS_PORT=8080
WS_PATH=/ws
WS_PING_INTERVAL=25
WS_PING_TIMEOUT=60
WS_MAX_CONNECTIONS=10000


# =============================================================================
# BACKGROUND JOBS (Celery / ARQ / RQ)
# =============================================================================

CELERY_BROKER_URL=redis://:changeme_redis_password@localhost:6379/3
CELERY_RESULT_BACKEND=redis://:changeme_redis_password@localhost:6379/4
CELERY_TASK_ALWAYS_EAGER=false
CELERY_WORKER_CONCURRENCY=4
CELERY_MAX_TASKS_PER_CHILD=1000


# =============================================================================
# DOCKER / KUBERNETES
# =============================================================================

# Container registry
DOCKER_REGISTRY=ghcr.io/alakhservice
DOCKER_TAG=latest

# Kubernetes namespace
K8S_NAMESPACE=alakhservice-production
KUBECONFIG=~/.kube/config


# =============================================================================
# TERRAFORM / CLOUD
# =============================================================================

# AWS
TF_VAR_aws_region=us-east-1
TF_VAR_environment=production
TF_VAR_project=alakhservice

# GCP
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# Terraform state backend
TF_STATE_BUCKET=alakhservice-terraform-state
TF_STATE_KEY=alakhservice/terraform.tfstate
TF_STATE_REGION=us-east-1
TF_LOCK_TABLE=alakhservice-terraform-locks


# =============================================================================
# MISC
# =============================================================================

# Webhook secret for GitHub Actions (CI/CD)
GITHUB_WEBHOOK_SECRET=changeme_github_webhook_secret

# Admin panel
ADMIN_EMAIL=admin@alakhservice.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin_password

# Support
SUPPORT_EMAIL=support@alakhservice.com
=======
# AlakhService — Root Environment Configuration
# Copy to .env and fill in real values
# WARNING: Never commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/alakhservice_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-super-secret-jwt-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# Service URLs
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:8001
USER_SERVICE_URL=http://localhost:8002
SHOP_SERVICE_URL=http://localhost:8003
BOOKING_SERVICE_URL=http://localhost:8004
PAYMENT_SERVICE_URL=http://localhost:8005
NOTIFICATION_SERVICE_URL=http://localhost:8006
TRACKING_SERVICE_URL=http://localhost:8007
QUEUE_SERVICE_URL=http://localhost:8008
DISPATCH_SERVICE_URL=http://localhost:8009
ANALYTICS_SERVICE_URL=http://localhost:8010
DISPUTE_SERVICE_URL=http://localhost:8011
TRUST_RISK_SERVICE_URL=http://localhost:8012
ADMIN_SERVICE_URL=http://localhost:8013
COMPLIANCE_SERVICE_URL=http://localhost:8014
PRICING_ENGINE_URL=http://localhost:8015
SERVICE_CATALOG_URL=http://localhost:8016

# -----------------------------------------------------------------------------
# Payment Gateway
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# -----------------------------------------------------------------------------
# SMS Provider
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@alakhservice.com

# -----------------------------------------------------------------------------
# Firebase (Push notifications)
# -----------------------------------------------------------------------------
FIREBASE_SERVER_KEY=your-firebase-server-key

# -----------------------------------------------------------------------------
# AWS S3
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=ap-south-1
S3_BUCKET_NAME=alakhservice-media

# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

