# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Jupyter Notebooks
.ipynb_checkpoints

# Distribution / packaging
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
junit.xml

# Translations
*.mo
*.pot

